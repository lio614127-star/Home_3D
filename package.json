{
  "name": "garden-house-3d",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "assets:download": "tsx scripts/assets/downloadAssets.ts",
    "assets:placeholders": "tsx scripts/assets/generatePlaceholderModels.ts",
    "assets:catalog": "tsx scripts/assets/generateAssetCatalog.ts",
    "assets:all": "npm run assets:download && npm run assets:placeholders && npm run assets:catalog",
    "assets:thumbnails": "tsx scripts/assets/generateAssetThumbnails.ts",
    "assets:validate": "tsx scripts/assets/validateAssetLibrary.ts",
    "assets:sweethome3d-import": "tsx scripts/assets/importSweetHome3D.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@react-three/drei": "^9.96.1",
    "@react-three/fiber": "^8.15.12",
    "konva": "^9.3.6",
    "polygon-clipping": "^0.15.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "three": "^0.160.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.2.1",
    "adm-zip": "^0.5.17",
    "obj2gltf": "^3.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
